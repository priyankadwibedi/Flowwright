OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
# true = sample demo only. Turn off via Record page toggle once OpenAI is configured.
FLOWWRIGHT_DEMO_MODE=true
FLOWWRIGHT_API_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://priyankadwibedi.github.io
MAX_UPLOAD_SIZE_MB=50
DATABASE_URL=sqlite:///./flowwright.db
LOG_LEVEL=INFO
OPENAI_TIMEOUT_SECONDS=45
OPENAI_MAX_RETRIES=2
MAX_KEYFRAMES=8
MAX_FRAME_WIDTH=1280
JPEG_QUALITY=75
